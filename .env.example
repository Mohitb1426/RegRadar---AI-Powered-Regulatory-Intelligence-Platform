# AWS Bedrock (Claude API)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_SESSION_TOKEN=your_aws_session_token_here_if_using_temporary_credentials
AWS_REGION=ap-south-1
AWS_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# AWS S3 (PDF storage)
AWS_BUCKET_NAME=regradar-pdfs

# Voyage AI (embeddings - free 50M tokens/month)
# Get your API key from: https://www.voyageai.com/
VOYAGE_API_KEY=your_voyage_api_key_here

# Pinecone (vector database - free tier)
# Get your API key from: https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=regradar

# PostgreSQL (Railway or your database provider)
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:your_password@host:port/railway

# JWT Authentication
# Generate a strong random secret key (at least 32 characters)
JWT_SECRET=your_random_secret_key_here_use_long_string_at_least_32_characters
JWT_EXPIRE_HOURS=168

# Application Settings
PORT=8000
ENVIRONMENT=development
